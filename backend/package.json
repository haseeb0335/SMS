{
  "name": "backend",
  "version": "1.0.0",
  "description": "School Management System - Desktop & Web",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "start": "nodemon api/index.js",
    "build": "npm i",
    "vercel-start": "node api/index.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder build --win --publish never"
  },
  "author": "Haseeb Ahmed",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "mongodb": "^7.1.0",
    "mongoose": "^7.8.9",
    "multer": "^2.1.1",
    "nodemon": "^2.0.22",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.haseeb.smsproject",
    "productName": "School Management System",
    "directories": {
      "output": "dist"
    },
    "win": {
  "target": ["nsis"],
  "cscLink": null,
  "verifyUpdateCodeSignature": false
},
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "School Management System"
    },
    "files": [
      "api/**/*",
      "models/**/*",
      "routes/**/*",
      "uploads/**/*",
      "main.cjs",
      "package.json",
      "node_modules/**/*"
    ]
  }
